[Unit]
Description=QE Group Draw live Bun server
After=network.target

[Service]
Type=simple
User=groupdraw-live
Group=groupdraw-live
WorkingDirectory=/srv/qe-group-draw-live/current
Environment=NODE_ENV=production
Environment=HOST=127.0.0.1
Environment=PORT=3010
Environment=STATE_FILE=/srv/qe-group-draw-live/shared/live-state.json
EnvironmentFile=-/srv/qe-group-draw-live/shared/live.env
ExecStart=/home/groupdraw-live/.bun/bin/bun ./server-dist/index.js
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/srv/qe-group-draw-live/shared
ProtectHome=read-only
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
ProtectClock=true
ProtectHostname=true
RestrictSUIDSGID=true
RestrictRealtime=true
LockPersonality=true
SystemCallArchitectures=native
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
CapabilityBoundingSet=
AmbientCapabilities=
UMask=027

[Install]
WantedBy=multi-user.target
