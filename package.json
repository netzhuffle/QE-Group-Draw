{
  "name": "qe-group-draw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "css:build": "bunx --bun postcss ./src/tailwind.css -o ./src/styles.css",
    "css:dev": "bunx --bun postcss ./src/tailwind.css -o ./src/styles.css --watch",
    "dev": "bun run css:dev & bun ./src/index.html",
    "serve:live": "bun ./src/server.ts",
    "build": "bun run css:build && bun build ./src/index.html --outdir ./dist --target browser --minify",
    "build:server": "bun build ./src/server.ts --target bun --outfile ./server-dist/index.js",
    "build:all": "bun run build && bun run build:server",
    "test": "bun test",
    "test:parallel": "bun test --parallel",
    "test:changed": "bun test --changed",
    "format": "bunx --bun oxfmt .",
    "format:check": "bunx --bun oxfmt . --check",
    "lint": "bunx --bun oxlint .",
    "check": "bun run format:check && bun run lint && bun run test",
    "check:ci": "bun run format:check && bun run lint && bun run test:parallel"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "^1.3.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lightningcss": "^1.32.0",
    "lightningcss-darwin-x64": "^1.32.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.20.0",
    "postcss": "^8.5.9",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.2.2"
  }
}
